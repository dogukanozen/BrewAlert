<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- BrewAlert Custom Theme — Warm color palette for a cozy brew app -->

    <Style Selector="Window">
        <Setter Property="Background" Value="#1a1a2e" />
    </Style>

    <!-- Accent Colors as Resources -->
    <Styles.Resources>
        <Color x:Key="BrewPrimary">#e07c24</Color>
        <Color x:Key="BrewSecondary">#c9956b</Color>
        <Color x:Key="BrewAccent">#f0a500</Color>
        <Color x:Key="BrewBackground">#1a1a2e</Color>
        <Color x:Key="BrewSurface">#16213e</Color>
        <Color x:Key="BrewCard">#0f3460</Color>
        <Color x:Key="BrewTextPrimary">#eaeaea</Color>
        <Color x:Key="BrewTextSecondary">#a0a0b0</Color>
        <Color x:Key="BrewSuccess">#27ae60</Color>
        <Color x:Key="BrewDanger">#e74c3c</Color>

        <SolidColorBrush x:Key="BrewPrimaryBrush" Color="{StaticResource BrewPrimary}" />
        <SolidColorBrush x:Key="BrewSecondaryBrush" Color="{StaticResource BrewSecondary}" />
        <SolidColorBrush x:Key="BrewAccentBrush" Color="{StaticResource BrewAccent}" />
        <SolidColorBrush x:Key="BrewBackgroundBrush" Color="{StaticResource BrewBackground}" />
        <SolidColorBrush x:Key="BrewSurfaceBrush" Color="{StaticResource BrewSurface}" />
        <SolidColorBrush x:Key="BrewCardBrush" Color="{StaticResource BrewCard}" />
        <SolidColorBrush x:Key="BrewTextPrimaryBrush" Color="{StaticResource BrewTextPrimary}" />
        <SolidColorBrush x:Key="BrewTextSecondaryBrush" Color="{StaticResource BrewTextSecondary}" />
        <SolidColorBrush x:Key="BrewSuccessBrush" Color="{StaticResource BrewSuccess}" />
        <SolidColorBrush x:Key="BrewDangerBrush" Color="{StaticResource BrewDanger}" />
    </Styles.Resources>

    <!-- Large, touch-friendly buttons for Raspberry Pi screen -->
    <Style Selector="Button.brew-primary">
        <Setter Property="Background" Value="{StaticResource BrewPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Padding" Value="24,14" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="MinHeight" Value="50" />
    </Style>

    <Style Selector="Button.brew-danger">
        <Setter Property="Background" Value="{StaticResource BrewDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Padding" Value="24,14" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="MinHeight" Value="50" />
    </Style>

    <!-- Compact nav button for top toolbar -->
    <Style Selector="Button.brew-nav-btn">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinHeight" Value="38" />
    </Style>

    <!-- Card style for profile items -->
    <Style Selector="Border.brew-card">
        <Setter Property="Background" Value="{StaticResource BrewCardBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Card hover lift effect -->
    <Style Selector="Button:pointerover > Border.brew-card">
        <Setter Property="RenderTransform" Value="scale(1.04)" />
    </Style>

    <!-- Title text -->
    <Style Selector="TextBlock.brew-title">
        <Setter Property="Foreground" Value="{StaticResource BrewTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Subtitle text -->
    <Style Selector="TextBlock.brew-subtitle">
        <Setter Property="Foreground" Value="{StaticResource BrewTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Large timer display -->
    <Style Selector="TextBlock.brew-timer">
        <Setter Property="Foreground" Value="{StaticResource BrewAccentBrush}" />
        <Setter Property="FontSize" Value="72" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

</Styles>
