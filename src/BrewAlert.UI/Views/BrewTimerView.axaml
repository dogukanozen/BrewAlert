<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BrewAlert.UI.ViewModels"
             xmlns:conv="using:BrewAlert.UI.Converters"
             x:Class="BrewAlert.UI.Views.BrewTimerView"
             x:DataType="vm:BrewTimerViewModel">

    <UserControl.Resources>
        <conv:TimeSpanToStringConverter x:Key="TimeSpanConverter" />
    </UserControl.Resources>

    <!-- Use a Viewbox wrapper so entire timer UI scales with window size -->
    <Grid RowDefinitions="*,Auto">
        <!-- Timer Display -->
        <ScrollViewer Grid.Row="0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="12"
                        Margin="16">

                <!-- Profile Icon — scales via Viewbox for any resolution -->
                <Viewbox MaxHeight="100" Stretch="Uniform" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ProfileIcon}"
                               FontSize="80" />
                </Viewbox>

                <!-- Countdown — auto-scaling with Viewbox, no fixed height -->
                <Viewbox MaxHeight="140"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         Margin="0,8">
                    <TextBlock Text="{Binding Remaining, Converter={StaticResource TimeSpanConverter}}"
                               Classes="brew-timer" />
                </Viewbox>

                <!-- Progress Bar — stretches to fill available width -->
                <ProgressBar Value="{Binding Progress}"
                             Maximum="1"
                             Height="10"
                             HorizontalAlignment="Stretch"
                             CornerRadius="5"
                             Margin="24,0"
                             Foreground="{StaticResource BrewAccentBrush}"
                             Background="{StaticResource BrewSurfaceBrush}" />

                <!-- Status -->
                <TextBlock Text="{Binding StatusText}"
                           Classes="brew-subtitle"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />

                <!-- Notification Status -->
                <TextBlock Text="{Binding NotificationStatus}"
                           Classes="brew-subtitle"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           IsVisible="{Binding NotificationStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons — wrap on narrow screens -->
        <WrapPanel Grid.Row="1"
                   HorizontalAlignment="Center"
                   Margin="8,0,8,16">

            <!-- Pause button (visible when running and NOT paused) -->
            <Button Content="⏸ Pause"
                    Classes="brew-primary"
                    Command="{Binding PauseCommand}"
                    Margin="6"
                    MinWidth="140">
                <Button.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="IsRunning" />
                        <Binding Path="!IsPaused" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Resume button (visible when running and paused) -->
            <Button Content="▶ Resume"
                    Classes="brew-primary"
                    Command="{Binding ResumeCommand}"
                    Margin="6"
                    MinWidth="140">
                <Button.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="IsRunning" />
                        <Binding Path="IsPaused" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Cancel (visible while running) -->
            <Button Content="✕ Cancel"
                    Classes="brew-danger"
                    Command="{Binding CancelCommand}"
                    Margin="6"
                    MinWidth="140"
                    IsVisible="{Binding IsRunning}" />

            <!-- Back (visible when completed) -->
            <Button Content="← Back to Brews"
                    Classes="brew-primary"
                    Command="{Binding BackToProfilesCommand}"
                    Margin="6"
                    MinWidth="140"
                    IsVisible="{Binding IsCompleted}" />
        </WrapPanel>
    </Grid>
</UserControl>
