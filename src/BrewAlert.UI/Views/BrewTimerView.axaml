<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BrewAlert.UI.ViewModels"
             xmlns:conv="using:BrewAlert.UI.Converters"
             x:Class="BrewAlert.UI.Views.BrewTimerView"
             x:DataType="vm:BrewTimerViewModel">

    <UserControl.Resources>
        <conv:TimeSpanToStringConverter x:Key="TimeSpanConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.brew-compact">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="12,6" LastChildFill="True">

        <!-- Buttons pinned to the bottom -->
        <WrapPanel DockPanel.Dock="Bottom"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,0">

            <Button Content="{Binding PauseButtonText}"
                    Classes="brew-primary brew-compact"
                    Command="{Binding PauseCommand}"
                    Margin="4"
                    MinWidth="110">
                <Button.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="IsRunning" />
                        <Binding Path="!IsPaused" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <Button Content="{Binding ResumeButtonText}"
                    Classes="brew-primary brew-compact"
                    Command="{Binding ResumeCommand}"
                    Margin="4"
                    MinWidth="110">
                <Button.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="IsRunning" />
                        <Binding Path="IsPaused" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <Button Content="{Binding CancelButtonText}"
                    Classes="brew-danger brew-compact"
                    Command="{Binding CancelCommand}"
                    Margin="4"
                    MinWidth="110"
                    IsVisible="{Binding IsRunning}" />

            <Button Content="{Binding BackButtonText}"
                    Classes="brew-primary brew-compact"
                    Command="{Binding BackToProfilesCommand}"
                    Margin="4"
                    MinWidth="110"
                    IsVisible="{Binding IsCompleted}" />
        </WrapPanel>

        <!-- Centered content; fixed sizes so nothing scales wildly -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8">

            <TextBlock Text="{Binding ProfileIcon}"
                       FontSize="44"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{Binding Remaining, Converter={StaticResource TimeSpanConverter}}"
                       Classes="brew-timer"
                       FontSize="72" />

            <ProgressBar Value="{Binding Progress}"
                         Maximum="1"
                         Height="8"
                         Width="320"
                         HorizontalAlignment="Center"
                         CornerRadius="4"
                         Margin="0,4"
                         Foreground="{StaticResource BrewAccentBrush}"
                         Background="{StaticResource BrewSurfaceBrush}" />

            <TextBlock Text="{Binding StatusText}"
                       Classes="brew-subtitle"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />

            <TextBlock Text="{Binding NotificationStatus}"
                       Classes="brew-subtitle"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       IsVisible="{Binding NotificationStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
    </DockPanel>
</UserControl>
