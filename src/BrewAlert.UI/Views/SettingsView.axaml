<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BrewAlert.UI.ViewModels"
             x:Class="BrewAlert.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="12"
                    HorizontalAlignment="Stretch">

            <!-- ══════════════════ Süre Ayarları ══════════════════ -->
            <TextBlock Text="Süre Ayarları"
                       Classes="brew-title"
                       Margin="0,0,0,4" />

            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BrewSurfaceBrush}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Content="-" Command="{Binding DecreaseTimeCommand}" Width="44" MinHeight="44" Padding="0" HorizontalContentAlignment="Center" Margin="0,0,12,0" Classes="brew-primary"/>
                                <TextBlock Grid.Column="3" Text="{Binding Duration.TotalMinutes, StringFormat='{}{0} dk'}" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" Width="60" TextAlignment="Center" Margin="0,0,12,0" />
                                <Button Grid.Column="4" Content="+" Command="{Binding IncreaseTimeCommand}" Width="44" MinHeight="44" Padding="0" HorizontalContentAlignment="Center" Classes="brew-primary"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Varsayılanlara Sıfırla"
                    Command="{Binding ResetProfilesCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Classes="brew-danger"
                    HorizontalAlignment="Right" />

            <!-- ══════════════════ Bildirim Ayarları ══════════════════ -->
            <TextBlock Text="Bildirim Ayarları"
                       Classes="brew-title"
                       Margin="0,8,0,4" />

            <!-- Provider seçim bar -->
            <Border Background="{StaticResource BrewSurfaceBrush}"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Bildirim Kanalı"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="{StaticResource BrewTextSecondaryBrush}" />
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="🔗  Webhook"
                                Command="{Binding SetProviderCommand}"
                                CommandParameter="Webhook"
                                IsEnabled="{Binding !IsBusy}"
                                Classes="brew-primary"
                                Margin="0,0,8,0">
                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Style>
                                <Style Selector="Button[IsEnabled=true]">
                                    <Setter Property="Opacity" Value="1" />
                                </Style>
                            </Button.Styles>
                        </Button>
                        <Button Content="🔷  Graph API"
                                Command="{Binding SetProviderCommand}"
                                CommandParameter="Graph"
                                IsEnabled="{Binding !IsBusy}"
                                Classes="brew-primary">
                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Style>
                                <Style Selector="Button[IsEnabled=true]">
                                    <Setter Property="Opacity" Value="1" />
                                </Style>
                            </Button.Styles>
                        </Button>
                    </WrapPanel>

                    <!-- Seçili kanal etiketi -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Aktif kanal:"
                                   Foreground="{StaticResource BrewTextSecondaryBrush}"
                                   FontSize="12" />
                        <TextBlock Text="{Binding SelectedProvider}"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Webhook paneli ── -->
            <Border Background="{StaticResource BrewSurfaceBrush}"
                    CornerRadius="8"
                    Padding="12"
                    IsVisible="{Binding IsWebhookSelected}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="✅ Aktif — Teams Webhook"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   IsVisible="{Binding IsWebhookConfigured}" />
                        <TextBlock Text="⚠️ Yapılandırılmamış"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="OrangeRed"
                                   IsVisible="{Binding !IsWebhookConfigured}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="90,*">
                        <TextBlock Grid.Column="0" Text="Webhook URL"
                                   Foreground="{StaticResource BrewTextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding WebhookUrl}"
                                   FontFamily="Consolas,Menlo,monospace"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <TextBlock Text="BrewAlert:Notifications:Teams:WebhookUrl alanını appsettings.Development.json'da ayarlayın."
                               Foreground="{StaticResource BrewTextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- ── Graph API paneli ── -->
            <Border Background="{StaticResource BrewSurfaceBrush}"
                    CornerRadius="8"
                    Padding="12"
                    IsVisible="{Binding IsGraphSelected}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="✅ Aktif — Teams Graph API"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   IsVisible="{Binding IsGraphConfigured}" />
                        <TextBlock Text="⚠️ Yapılandırılmamış"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="OrangeRed"
                                   IsVisible="{Binding !IsGraphConfigured}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Tenant ID"
                                       Foreground="{StaticResource BrewTextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding TenantId}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Client ID"
                                       Foreground="{StaticResource BrewTextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding ClientId}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Chat ID"
                                       Foreground="{StaticResource BrewTextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding ChatId}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="BrewAlert:Notifications:TeamsGraph:* alanlarını appsettings.Development.json'da ayarlayın."
                               Foreground="{StaticResource BrewTextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- ══════════════════ Test ══════════════════ -->
            <StackPanel Spacing="10">
                <TextBlock Text="Test"
                           Classes="brew-subtitle" />

                <WrapPanel Orientation="Horizontal">
                    <Button Content="Bağlantıyı Test Et"
                            Classes="brew-primary"
                            Command="{Binding TestConnectionCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Margin="0,0,8,8" />

                    <Button Content="Test Bildirimi Gönder"
                            Command="{Binding SendTestNotificationCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Margin="0,0,0,8" />
                </WrapPanel>

                <TextBlock Text="{Binding TestResult}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           IsVisible="{Binding TestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
