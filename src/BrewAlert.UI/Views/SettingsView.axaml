<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BrewAlert.UI.ViewModels"
             x:Class="BrewAlert.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="12"
                    HorizontalAlignment="Stretch">

            <TextBlock Text="Süre Ayarları"
                       Classes="brew-title"
                       Margin="0,0,0,4" />

            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BrewSurfaceBrush}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                
                                <Button Grid.Column="2" Content="-" Command="{Binding DecreaseTimeCommand}" Width="44" MinHeight="44" Padding="0" HorizontalContentAlignment="Center" Margin="0,0,12,0" Classes="brew-primary"/>
                                <TextBlock Grid.Column="3" Text="{Binding Duration.TotalMinutes, StringFormat='{}{0} dk'}" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" Width="60" TextAlignment="Center" Margin="0,0,12,0" />
                                <Button Grid.Column="4" Content="+" Command="{Binding IncreaseTimeCommand}" Width="44" MinHeight="44" Padding="0" HorizontalContentAlignment="Center" Classes="brew-primary"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Varsayılanlara Sıfırla"
                    Command="{Binding ResetProfilesCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Classes="brew-danger"
                    HorizontalAlignment="Right" />

            <TextBlock Text="Bildirim Ayarları"
                       Classes="brew-title"
                       Margin="0,8,0,4" />

            <!-- Status -->
            <Border Background="{StaticResource BrewSurfaceBrush}"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="✅ Aktif — Teams Graph API"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   IsVisible="{Binding IsConfigured}" />
                        <TextBlock Text="⚠️ Yapılandırılmamış"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="OrangeRed"
                                   IsVisible="{Binding !IsConfigured}" />
                    </StackPanel>

                    <!-- Config details — stacks vertically on narrow, side-by-side on wide -->
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Tenant ID"
                                       Foreground="{StaticResource BrewTextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding TenantId}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Client ID"
                                       Foreground="{StaticResource BrewTextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding ClientId}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Chat ID"
                                       Foreground="{StaticResource BrewTextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding ChatId}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="Ayarları değiştirmek için appsettings.Development.json veya ortam değişkenlerini kullanın."
                               Foreground="{StaticResource BrewTextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Spacing="10">
                <TextBlock Text="Test"
                           Classes="brew-subtitle" />

                <!-- Buttons wrap when window is narrow -->
                <WrapPanel Orientation="Horizontal">
                    <Button Content="Bağlantıyı Test Et"
                            Classes="brew-primary"
                            Command="{Binding TestConnectionCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Margin="0,0,8,8" />

                    <Button Content="Test Bildirimi Gönder"
                            Command="{Binding SendTestNotificationCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Margin="0,0,0,8" />
                </WrapPanel>

                <TextBlock Text="{Binding TestResult}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           IsVisible="{Binding TestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
