<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BrewAlert.UI.ViewModels"
             x:Class="BrewAlert.UI.Views.ProfileListView"
             x:DataType="vm:ProfileListViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding PageTitle}"
                   Classes="brew-title"
                   Margin="0,0,0,4" />

        <!-- Loading indicator -->
        <TextBlock Grid.Row="1"
                   Text="{Binding LoadingText}"
                   Classes="brew-subtitle"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,8"
                   IsVisible="{Binding IsLoading}" />

        <!-- Recent brews — hidden when empty -->
        <StackPanel Grid.Row="2"
                    Margin="0,6,0,14"
                    IsVisible="{Binding HasRecentBrews}">
            <TextBlock Text="{Binding RecentBrewsLabel}"
                       Classes="brew-subtitle"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="6,0,0,8" />
            <ItemsControl ItemsSource="{Binding RecentBrews}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BrewSurfaceBrush}"
                                CornerRadius="8"
                                Padding="10,8"
                                Margin="4"
                                Width="216"
                                MinHeight="68">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="10">
                                <Border Grid.RowSpan="2"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Background="{StaticResource BrewCardBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding Name}"
                                           Grid.Column="1"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrewTextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="112" />
                                <TextBlock Text="{Binding RelativeTime}"
                                           Grid.Column="2"
                                           FontSize="12"
                                           Foreground="{StaticResource BrewTextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DurationText}"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           FontSize="12"
                                           Foreground="{StaticResource BrewTextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Profile Cards — WrapPanel auto-flows cards to fill available width -->
        <ScrollViewer Grid.Row="3">
            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding $parent[ItemsControl].((vm:ProfileListViewModel)DataContext).SelectProfileCommand}"
                                CommandParameter="{Binding}"
                                Margin="6"
                                Padding="0"
                                Background="Transparent"
                                CornerRadius="16">
                            <Border Classes="brew-card"
                                    Width="180" Height="160">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="6">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="40"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrewTextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="160" />
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{StaticResource BrewTextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxWidth="160" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
