<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BrewAlert.UI.ViewModels"
             x:Class="BrewAlert.UI.Views.ProfileListView"
             x:DataType="vm:ProfileListViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select Your Brew"
                   Classes="brew-title"
                   Margin="0,0,0,12" />

        <!-- Profile Cards — WrapPanel auto-flows cards to fill available width -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding $parent[ItemsControl].((vm:ProfileListViewModel)DataContext).SelectProfileCommand}"
                                CommandParameter="{Binding}"
                                Margin="6"
                                Padding="0"
                                Background="Transparent"
                                CornerRadius="16">
                            <Border Classes="brew-card"
                                    Width="180" Height="160">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="6">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="40"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrewTextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="160" />
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{StaticResource BrewTextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxWidth="160" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
